{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NEXT_PUBLIC_NETWORK", "NEXT_PUBLIC_BASE_PATH"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "out/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": false
    },
    "typecheck": {
      "cache": false
    },
    "compile": {
      "outputs": ["artifacts/**", "typechain-types/**", "cache/**"]
    },
    "test": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
